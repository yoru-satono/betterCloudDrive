# Observability
GRAFANA_BASE_URL=/grafana
GRAFANA_AUTH_PROXY_SECRET=replace_with_random_grafana_auth_proxy_secret
GRAFANA_AUTH_PROXY_TTL_SECONDS=300
GF_SERVER_ROOT_URL=%(protocol)s://%(domain)s:%(http_port)s/grafana/
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GRAFANA_LOKI_DATASOURCE=Loki
GRAFANA_DS_LOKI_URL=http://loki:3100
GRAFANA_DS_TEMPO_URL=http://tempo:3200
LOKI_PORT=3100
LOKI_BASE_URL=http://loki:3100
TEMPO_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
METRICS_EXPORT_OTLP_ENABLED=false
TRACING_ENABLED=true
TRACING_SAMPLING_PROBABILITY=1.0
TRACING_EXPORT_OTLP_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_COLLECTOR_TEMPO_ENDPOINT=tempo:4317
PROMTAIL_LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
SYSTEM_LOG_DEFAULT_LIMIT=100
SYSTEM_LOG_MAX_LIMIT=500
AUDIT_LOG_ENABLED=true
AUDIT_FULL_EVENT_ENABLED=true
AUDIT_MAX_BODY_BYTES=8192
