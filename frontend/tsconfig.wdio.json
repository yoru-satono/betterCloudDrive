{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node", "mocha", "@wdio/globals/types"],
    "verbatimModuleSyntax": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "wdio.tauri.conf.ts",
    "e2e-tauri/**/*.ts",
    "e2e/helpers/**/*.ts"
  ]
}
